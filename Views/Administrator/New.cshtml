@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    @Html.Partial("~/Views/Shared/Head.cshtml")
</head>
<body>
    <div id="biggestContainer">
        <form>
            <label for="userName">Số điện thoại/Email/Tên đăng nhập:</label><br>
            <input class="config-max-width" type="text" id="userName" value=""><br><br>

            <label for="passWord">Mật khẩu:</label><br>
            <input class="config-max-width" type="password" id="passWord" value=""><br><br>

            <label for="repassWord">Nhập lại mật khẩu:</label><br>
            <input class="config-max-width" type="password" id="repassWord" value=""><br><br>

            <label for="privilege">Nhập quyền</label><br />
            <select id="privilege">
                <option value="1">Full quyền</option>
                <option value="2">Thêm mới/cập nhật sản phẩm, nhà phát hành, tạo sản phẩm bán, set giá</option>
            </select><br><br>
        </form>
        <div>
            <button type="button" onclick="New_AddAdministrator()">Thêm người dùng</button>
        </div>

        <div>
            <a href="/Administrator/Login" target="_self">Đăng nhập</a>
        </div> <br />
    </div>
    <script src="~/Scripts/web.play.with.me.update.width.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.common.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.action.common.js?v=20260610"></script>
    <script src="~/Scripts/Administrator/New.js?v=20260610"></script>
</body>
</html>
