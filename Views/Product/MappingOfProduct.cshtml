
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    @Html.Partial("~/Views/Shared/Head.cshtml")
    <link rel="stylesheet" href="~/Content/web.play.with.me.table.show.data.css?v=20260610">
    <link rel="stylesheet" href="~/Content/Product/MappingOfProduct.css?v=20260610">
</head>
<body onload="GetListCommonItemMappingFromProductId()">
    <div id="biggestContainer">
        <div class="config-max-width padding-container" id="result-find-id">
            <div class="fmx09gx8">
                <button type="button" onclick="UpdateQuantityToTMDTFromListCommonItem(false, listCommonItem)"
                        title="Cập nhật số lượng sản phẩm lên Tiki, Shopee, Lazada và hiện kết quả">
                    Cập Nhật Số Lượng Trên Sàn
                </button>

            </div>
            <div class="config-max-width padding-container">
                <div class="fcnal986j">
                    <div class="lk09Jbvrd">
                        <input type="radio" id="nvnlFxjg" name="status-radio" value="All"
                               onclick="ShowResultWithFilter()" />
                        <label for="nvnlFxjg">Tất cả</label>
                    </div>
                    <div class="lk09Jbvrd">
                        <input type="radio" id="nvnlFfesg" name="status-radio" value="On" checked
                               onclick="ShowResultWithFilter()" />
                        <label for="nvnlFfesg">Đang bán</label>
                    </div>
                    <div class="lk09Jbvrd">
                        <input type="radio" id="nvnlFfesg" name="status-radio" value="Off"
                               onclick="ShowResultWithFilter()" />
                        <label for="nvnlFfesg">Dừng bán</label>
                    </div>
                </div>
                <table id="myTable">
                    @Html.Partial("~/Views/Shared/Product/TableOfMapping.cshtml")
                </table>
            </div>

            <div class="mapping_sample" style="display:none;">
                <table>
                    <tr>
                        <th style="display:none">Mã Item</th>
                        <th>STT</th>
                        <th>Tên</th>
                        <th>SL</th>
                        <th>SL Kho</th>
                    </tr>
                </table>
            </div>
        </div>

        @Html.Partial("~/Views/Shared/DoesntFindId.cshtml")
    </div>
    <script src="~/Scripts/web.play.with.me.update.width.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.common.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.mapping.of.item.model.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.action.common.js?v=20260610"></script>
    <script src="~/Scripts/Product/MappingOfProduct.js?v=20260610"></script>
</body>
</html>
