@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    @Html.Partial("~/Views/Shared/Head.cshtml")
    <link rel="stylesheet" href="~/Content/Home/Search.css?v=20260610">
</head>
<body onload="Search()">
    <div id="biggestContainer">
        @Html.Partial("~/Views/Shared/biggestContainer_Top.cshtml")

        <div>
            <div id="empty-result" style="display:none">
                <p>Kết quả trống</p>
            </div>
            <div id="search-result" style="display:none">
                @Html.Partial("~/Views/Shared/Home/Item.cshtml"@*, item*@)
                <text id="list-item-data" style="display:none">@ViewData["dataListItem"]</text>
                <div id="biggestContainer_body_wraper_item"
                     data-count-result=@ViewData["dataCountResult"]>
                </div>
                @Html.Partial("~/Views/Shared/RowsDistance.cshtml")
                @Html.Partial("~/Views/Shared/GoToPage.cshtml")
            </div>
        </div>

        @Html.Partial("~/Views/Shared/biggestContainer_Bottom.cshtml")
    </div>
    <script src="~/Scripts/web.play.with.me.update.width.js"></script>
    <script src="~/Scripts/web.play.with.me.update.width.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.common.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.cart.cookie.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.paging.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.action.common.js?v=20260610"></script>
    <script src="~/Scripts/Home/Search.js?v=20260610"></script>
</body>
</html>
