
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    @Html.Partial("~/Views/Shared/Head.cshtml")
    <link rel="stylesheet" href="~/Content/web.play.with.me.table.show.data.css?v=20260610">
</head>
<body>

    <div id="biggestContainer">
        <div id="result-find-id">
            <div>
                <label for="category-id">Category:</label>
                <input class="config-max-width margin-vertical" id="category-id"
                       value="@ViewData["categoryName"]">
            </div>

            <div>
                <button type="button" style="margin-right:20px;" onclick="UpdateCategory()" disabled
                        title="Thể loại theo TIKI nên không cần thêm mới bằng tay">Cập Nhật</button>
                <button type="button" onclick="DeleteCategory()"> Xóa</button>
            </div>
        </div>
        @Html.Partial("~/Views/Shared/DoesntFindId.cshtml")
    </div>
    <script src="~/Scripts/web.play.with.me.update.width.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.common.js?v=20260610"></script>
    <script src="~/Scripts/web.play.with.me.action.common.js?v=20260610"></script>
    <script src="~/Scripts/Category/UpdateDelete.js?v=20260610"></script>
</body>
</html>
